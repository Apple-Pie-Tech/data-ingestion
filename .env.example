# Runtime
INGEST_API_KEY=local-dev-ingest-key
MAX_AUDIO_BYTES=25000000
REQUEST_TIMEOUT_SECONDS=60

# Qdrant
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=apple_pie_story_chunks

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://example.invalid/openai/v1/
AZURE_OPENAI_API_KEY=fake-azure-openai-api-key
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-large
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
SEMANTIC_SIMILARITY_THRESHOLD=0.8
MIN_CHUNK_CHARS=350
MAX_CHUNK_CHARS=1400
CHUNK_OVERLAP_SENTENCES=1

# Gradium
GRADIUM_API_BASE_URL=https://example.invalid
GRADIUM_API_KEY=
GRADIUM_TRANSCRIPTION_MODEL=demo-transcription-model
GRADIUM_TRANSCRIPTION_TRANSPORT=rest
GRADIUM_TRANSCRIPTION_PATH=/v1/audio/transcriptions
GRADIUM_TIMEOUT_SECONDS=60
